{
  "name": "chrome-wsl",
  "description": "Starts Chrome in Windows from Auggie CLI running in WSL",
  "version": "1.0.1",
  "author": {
    "name": "David Young"
  },
  "keywords": ["hook", "mcp", "chrome", "wsl"],
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--slim",
        "--isolated",
        "--browser-url=http://127.0.0.1:9222"
      ]
    }
  }
}
