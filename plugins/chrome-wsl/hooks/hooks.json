{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp:.*chrome-devtools.*",
        "hooks": [
          {
            "type": "command",
            "command": "${AUGMENT_PLUGIN_ROOT}/hooks/start-chrome-wsl.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${AUGMENT_PLUGIN_ROOT}/hooks/stop-chrome-wsl.sh"
          }
        ]
      }
    ]
  }
}
